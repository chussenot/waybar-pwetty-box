// Waybar config for the headless screenshot harness: a single bar hosting only
// our CFFI module, sized generously so the tile is clearly visible in the shot.
{
  "layer": "top",
  "position": "top",
  "height": 84,
  "margin-top": 8,
  "margin-left": 8,
  "modules-center": ["cffi/pwetty"],

  "cffi/pwetty": {
    "module_path": "/home/zor/Perso/pwetty-box-rs/target/release/libpwetty_box.so",
    "width": 320,
    "height": 72,
    "fps": 30,
    "exec": "echo '{\"load\":6.4}'",
    "interval": 5,
    "font_size": 14,
    "background_shader": "/home/zor/Perso/pwetty-box-rs/examples/shaders/reactive.glsl",
    "shader_uniforms": { "u_load": "{{ (load | float) / 8.0 }}" },
    "format": "<span size='small' foreground='#f0f0f0'>load</span>\n<span size='xx-large' weight='bold' foreground='#ffffff'>{{ load }}</span>"
  }
}
